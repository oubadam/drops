# Optional: Solana JSON-RPC for `/api/pump-coin` on-chain bonding curve reads (defaults to public mainnet).
SOLANA_RPC_URL=

# PumpPortal lightning create (server-side)
PUMPPORTAL_API_KEY=

# Pinata JWT for https://uploads.pinata.cloud/v3/files
PINATA_JWT=

# Official $drops mint to exclude from home trending/explore (optional)
NEXT_PUBLIC_OFFICIAL_DROPS_MINT=

# Privy (https://dashboard.privy.io) — required for Sign in / wallet + email auth in the top bar
NEXT_PUBLIC_PRIVY_APP_ID=

# Supabase: canonical launch registry (Postgres). Run supabase/migrations/*.sql in the project.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
